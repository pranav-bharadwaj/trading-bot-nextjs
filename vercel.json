{
  "buildCommand": "next build",
  "outputDirectory": "out",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://34.100.177.78.nip.io/api/:path*"
    }
  ]
}